{
  "manifest_version": 3,
  "name": "Idle Tab Grouper",
  "version": "0.2.0",
  "description": "Agrupa abas automaticamente depois de um período de inatividade e recolhe grupos inativos.",
  "permissions": ["tabs", "tabGroups", "storage", "alarms"],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Idle Tab Grouper",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
