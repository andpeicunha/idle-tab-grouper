{
  "manifest_version": 3,
  "name": "Idle Tab Grouper",
  "version": "0.2.5",
  "description": "Agrupa e descarta abas inativas com segurança, além de mostrar economia estimada de RAM localmente.",
  "permissions": ["tabs", "tabGroups", "storage", "alarms", "contextMenus"],
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_title": "Idle Tab Grouper",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
